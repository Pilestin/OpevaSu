# Bu dosya bilgilendirme amaclidir.
# Aktif ortam degiskenleri repo kokundeki `.env` dosyasindan okunur.
# Ornek alanlar:
# EXPO_PUBLIC_API_BASE_URL=http://YOUR_SERVER_HOST:3003
# EXPO_PUBLIC_FLEET_VEHICLES_URL=http://YOUR_SERVER_HOST:3001/api/vehicles/locations/fiware
# REMOTE_FLEET_API_BASE_URL=http://YOUR_SERVER_HOST:3001/api
# EXPO_PUBLIC_MAPTILER_KEY=your_maptiler_key
# EXPO_PUBLIC_MAPTILER_STYLE_ID=streets-v2
# EXPO_PUBLIC_MAP_STYLE_URL=https://api.maptiler.com/maps/streets-v2/style.json?key=YOUR_KEY
# EXPO_PUBLIC_TOMTOM_TRAFFIC_KEY=your_tomtom_traffic_key
# EXPO_PUBLIC_TOMTOM_TRAFFIC_STYLE=relative0
# GOOGLE_MAPS_API_KEY=your_google_maps_key
